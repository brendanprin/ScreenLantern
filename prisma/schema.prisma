generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InteractionType {
  WATCHLIST
  WATCHED
  LIKE
  DISLIKE
  HIDE
}

enum SourceContext {
  SOLO
  GROUP
  MANUAL
  IMPORTED
  NETFLIX_IMPORTED
}

enum RecommendationMode {
  SOLO
  GROUP
}

enum MediaType {
  MOVIE
  TV
}

enum HouseholdRole {
  OWNER
  MEMBER
}

enum ReminderCategory {
  AVAILABLE_NOW
  WATCHLIST_RESURFACE
  GROUP_WATCH_CANDIDATE
}

enum ReminderAggressiveness {
  LIGHT
  BALANCED
  PROACTIVE
}

enum SharedWatchlistScope {
  GROUP
  HOUSEHOLD
}

enum HouseholdActivityType {
  SHARED_SAVE_ADDED
  SHARED_SAVE_REMOVED
  GROUP_WATCH_RECORDED
  INVITE_CREATED
  INVITE_REVOKED
  INVITE_REDEEMED
  OWNERSHIP_TRANSFERRED
  MEMBER_REMOVED
}

enum TraktSyncStatus {
  SUCCESS
  ERROR
  NEEDS_REAUTH
}

enum TraktSyncMode {
  OFF
  DAILY
  ON_LOGIN_OR_APP_OPEN
}

enum TraktSyncTrigger {
  MANUAL
  AUTOMATIC
}

enum ImportSource {
  NETFLIX
}

enum UnresolvedImportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model Household {
  id                 String              @id @default(cuid())
  name               String
  users              User[]
  groups             HouseholdGroup[]
  invites            HouseholdInvite[]
  recommendationContexts UserRecommendationContext[]
  recommendationRuns RecommendationRun[]
  groupWatchSessions GroupWatchSession[]
  reminders          UserReminder[]
  reminderPreferences UserReminderPreference[]
  sharedWatchlistEntries SharedWatchlistEntry[]
  activities         HouseholdActivity[]
  traktConnections   UserTraktConnection[]
  aiConversations    AiConversation[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model User {
  id                 String                  @id @default(cuid())
  name               String
  email              String                  @unique
  passwordHash       String
  householdId        String
  householdRole      HouseholdRole           @default(MEMBER)
  preferredProviders String[]                @default([])
  defaultMediaType   MediaType?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  household          Household               @relation(fields: [householdId], references: [id], onDelete: Cascade)
  groupMemberships   HouseholdGroupMember[]
  createdGroups      HouseholdGroup[]        @relation("GroupCreator")
  createdInvites     HouseholdInvite[]       @relation("CreatedHouseholdInvites")
  redeemedInvites    HouseholdInvite[]       @relation("RedeemedHouseholdInvites")
  interactions       UserTitleInteraction[]
  recommendationContext UserRecommendationContext?
  requestedRuns      RecommendationRun[]     @relation("RunRequester")
  createdGroupWatchSessions GroupWatchSession[] @relation("CreatedGroupWatchSessions")
  reminders          UserReminder[]
  reminderPreference UserReminderPreference?
  sharedWatchlistEntries SharedWatchlistEntry[] @relation("SharedWatchlistSaver")
  householdActivities HouseholdActivity[] @relation("HouseholdActivityActor")
  traktConnection    UserTraktConnection?
  aiConversation     AiConversation?
  unresolvedImports  UnresolvedImport[]
}

model HouseholdGroup {
  id          String                 @id @default(cuid())
  householdId String
  name        String
  createdById String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  household   Household              @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy   User                   @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members     HouseholdGroupMember[]
  recommendationContexts UserRecommendationContext[] @relation("SavedRecommendationContextGroup")
  groupWatchSessions GroupWatchSession[] @relation("SavedGroupWatchSessions")
  reminders   UserReminder[]         @relation("SavedReminderGroup")
  sharedWatchlistEntries SharedWatchlistEntry[] @relation("SavedSharedWatchlistGroup")

  @@unique([householdId, name])
}

model HouseholdGroupMember {
  groupId String
  userId  String
  group   HouseholdGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

model HouseholdInvite {
  id           String        @id @default(cuid())
  householdId  String
  createdById  String
  redeemedById String?
  code         String        @unique
  role         HouseholdRole @default(MEMBER)
  expiresAt    DateTime
  redeemedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("CreatedHouseholdInvites", fields: [createdById], references: [id], onDelete: Cascade)
  redeemedBy   User?         @relation("RedeemedHouseholdInvites", fields: [redeemedById], references: [id], onDelete: SetNull)

  @@index([householdId, createdAt])
}

model TitleCache {
  id                 String                 @id @default(cuid())
  tmdbId             Int
  mediaType          MediaType
  title              String
  overview           String
  posterPath         String?
  backdropPath       String?
  releaseDate        DateTime?
  runtimeMinutes     Int?
  genres             String[]               @default([])
  voteAverage        Float?
  popularity         Float?
  providerSnapshot   Json?
  metadataJson       Json?
  lastSyncedAt       DateTime               @default(now())
  interactions       UserTitleInteraction[]
  groupWatchSessions GroupWatchSession[]
  reminders          UserReminder[]
  sharedWatchlistEntries SharedWatchlistEntry[]
  activities         HouseholdActivity[]
  unresolvedImports  UnresolvedImport[]

  @@unique([tmdbId, mediaType])
  @@index([lastSyncedAt])
}

model UserTitleInteraction {
  id              String          @id @default(cuid())
  userId          String
  titleCacheId    String
  interactionType InteractionType
  sourceContext   SourceContext   @default(MANUAL)
  groupRunId      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           TitleCache      @relation(fields: [titleCacheId], references: [id], onDelete: Cascade)

  @@unique([userId, titleCacheId, interactionType])
  @@index([userId, interactionType])
  @@index([userId, updatedAt])
}

model RecommendationRun {
  id              String             @id @default(cuid())
  householdId     String
  mode            RecommendationMode
  requestedById   String
  selectedUserIds String[]
  filtersJson     Json?
  resultTitleIds  String[]
  explanationJson Json?
  createdAt       DateTime           @default(now())
  household       Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  requestedBy     User               @relation("RunRequester", fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([householdId, mode, createdAt])
}

model UserRecommendationContext {
  id              String             @id @default(cuid())
  userId          String             @unique
  householdId     String
  mode            RecommendationMode @default(SOLO)
  selectedUserIds String[]           @default([])
  savedGroupId    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  household       Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  savedGroup      HouseholdGroup?    @relation("SavedRecommendationContextGroup", fields: [savedGroupId], references: [id], onDelete: SetNull)

  @@index([householdId, updatedAt])
}

model GroupWatchSession {
  id                 String         @id @default(cuid())
  householdId        String
  titleCacheId       String
  createdById        String
  savedGroupId       String?
  participantKey     String
  participantUserIds String[]       @default([])
  watchedAt          DateTime       @default(now())
  createdAt          DateTime       @default(now())
  household          Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  title              TitleCache     @relation(fields: [titleCacheId], references: [id], onDelete: Cascade)
  createdBy          User           @relation("CreatedGroupWatchSessions", fields: [createdById], references: [id], onDelete: Cascade)
  savedGroup         HouseholdGroup? @relation("SavedGroupWatchSessions", fields: [savedGroupId], references: [id], onDelete: SetNull)

  @@unique([householdId, titleCacheId, participantKey])
  @@index([householdId, watchedAt])
}

model UserReminder {
  id              String               @id @default(cuid())
  userId          String
  householdId     String
  titleCacheId    String
  mode            RecommendationMode
  category        ReminderCategory
  contextKey      String
  contextLabel    String
  selectedUserIds String[]             @default([])
  savedGroupId    String?
  summary         String
  detail          String?
  explanationJson Json?
  isActive        Boolean              @default(true)
  readAt          DateTime?
  dismissedAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  household       Household            @relation(fields: [householdId], references: [id], onDelete: Cascade)
  title           TitleCache           @relation(fields: [titleCacheId], references: [id], onDelete: Cascade)
  savedGroup      HouseholdGroup?      @relation("SavedReminderGroup", fields: [savedGroupId], references: [id], onDelete: SetNull)

  @@unique([userId, contextKey, category, titleCacheId])
  @@index([userId, contextKey, isActive, readAt])
  @@index([householdId, updatedAt])
}

model UserReminderPreference {
  id                          String                 @id @default(cuid())
  userId                      String                 @unique
  householdId                 String
  enableAvailableNow          Boolean                @default(true)
  enableWatchlistResurface    Boolean                @default(true)
  enableGroupWatchCandidate   Boolean                @default(true)
  enableSoloReminders         Boolean                @default(true)
  enableGroupReminders        Boolean                @default(true)
  aggressiveness              ReminderAggressiveness @default(BALANCED)
  allowDismissedReappear      Boolean                @default(false)
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt
  user                        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  household                   Household              @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, updatedAt])
}

model UserTraktConnection {
  id                   String          @id @default(cuid())
  userId               String          @unique
  householdId          String
  traktUserId          String?
  traktUsername        String?
  accessTokenEncrypted String
  refreshTokenEncrypted String
  expiresAt            DateTime
  scope                String?
  syncMode             TraktSyncMode   @default(DAILY)
  lastActivitiesJson   Json?
  lastSyncTrigger      TraktSyncTrigger?
  lastSyncSummaryJson  Json?
  lastSyncAttemptedAt  DateTime?
  lastSyncedAt         DateTime?
  lastSyncStatus       TraktSyncStatus?
  lastSyncError        String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  household            Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, updatedAt])
  @@index([householdId, syncMode, lastSyncAttemptedAt])
}

model AiConversation {
  id              String    @id @default(cuid())
  userId          String    @unique
  householdId     String
  messagesJson    Json
  lastContextJson Json?
  threadStateJson Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, updatedAt])
}

model SharedWatchlistEntry {
  id              String               @id @default(cuid())
  householdId     String
  titleCacheId    String
  scope           SharedWatchlistScope
  contextKey      String
  contextLabel    String
  selectedUserIds String[]             @default([])
  savedGroupId    String?
  savedById       String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  household       Household            @relation(fields: [householdId], references: [id], onDelete: Cascade)
  title           TitleCache           @relation(fields: [titleCacheId], references: [id], onDelete: Cascade)
  savedGroup      HouseholdGroup?      @relation("SavedSharedWatchlistGroup", fields: [savedGroupId], references: [id], onDelete: SetNull)
  savedBy         User                 @relation("SharedWatchlistSaver", fields: [savedById], references: [id], onDelete: Cascade)

  @@unique([savedById, contextKey, titleCacheId])
  @@index([householdId, contextKey, titleCacheId])
  @@index([householdId, scope, updatedAt])
}

model HouseholdActivity {
  id          String                @id @default(cuid())
  householdId String
  actorUserId String?
  titleCacheId String?
  type        HouseholdActivityType
  contextLabel String?
  summary     String
  detail      String?
  metadataJson Json?
  createdAt   DateTime              @default(now())
  household   Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  actor       User?                 @relation("HouseholdActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  title       TitleCache?           @relation(fields: [titleCacheId], references: [id], onDelete: SetNull)

  @@index([householdId, createdAt])
  @@index([householdId, type, createdAt])
}

model UnresolvedImport {
  id                   String                 @id @default(cuid())
  userId               String
  source               ImportSource
  rawTitle             String
  status               UnresolvedImportStatus @default(PENDING)
  resolvedTitleCacheId String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  resolvedTitle        TitleCache?            @relation(fields: [resolvedTitleCacheId], references: [id], onDelete: SetNull)

  @@unique([userId, source, rawTitle])
  @@index([userId, source, status])
}
