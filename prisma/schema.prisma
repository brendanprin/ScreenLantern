generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InteractionType {
  WATCHLIST
  WATCHED
  LIKE
  DISLIKE
  HIDE
}

enum SourceContext {
  SOLO
  GROUP
  MANUAL
}

enum RecommendationMode {
  SOLO
  GROUP
}

enum MediaType {
  MOVIE
  TV
}

enum HouseholdRole {
  OWNER
  MEMBER
}

model Household {
  id                 String              @id @default(cuid())
  name               String
  users              User[]
  groups             HouseholdGroup[]
  invites            HouseholdInvite[]
  recommendationContexts UserRecommendationContext[]
  recommendationRuns RecommendationRun[]
  groupWatchSessions GroupWatchSession[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model User {
  id                 String                  @id @default(cuid())
  name               String
  email              String                  @unique
  passwordHash       String
  householdId        String
  householdRole      HouseholdRole           @default(MEMBER)
  preferredProviders String[]                @default([])
  defaultMediaType   MediaType?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  household          Household               @relation(fields: [householdId], references: [id], onDelete: Cascade)
  groupMemberships   HouseholdGroupMember[]
  createdGroups      HouseholdGroup[]        @relation("GroupCreator")
  createdInvites     HouseholdInvite[]       @relation("CreatedHouseholdInvites")
  redeemedInvites    HouseholdInvite[]       @relation("RedeemedHouseholdInvites")
  interactions       UserTitleInteraction[]
  recommendationContext UserRecommendationContext?
  requestedRuns      RecommendationRun[]     @relation("RunRequester")
  createdGroupWatchSessions GroupWatchSession[] @relation("CreatedGroupWatchSessions")
}

model HouseholdGroup {
  id          String                 @id @default(cuid())
  householdId String
  name        String
  createdById String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  household   Household              @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy   User                   @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members     HouseholdGroupMember[]
  recommendationContexts UserRecommendationContext[] @relation("SavedRecommendationContextGroup")
  groupWatchSessions GroupWatchSession[] @relation("SavedGroupWatchSessions")

  @@unique([householdId, name])
}

model HouseholdGroupMember {
  groupId String
  userId  String
  group   HouseholdGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

model HouseholdInvite {
  id           String        @id @default(cuid())
  householdId  String
  createdById  String
  redeemedById String?
  code         String        @unique
  role         HouseholdRole @default(MEMBER)
  expiresAt    DateTime
  redeemedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("CreatedHouseholdInvites", fields: [createdById], references: [id], onDelete: Cascade)
  redeemedBy   User?         @relation("RedeemedHouseholdInvites", fields: [redeemedById], references: [id], onDelete: SetNull)

  @@index([householdId, createdAt])
}

model TitleCache {
  id                 String                 @id @default(cuid())
  tmdbId             Int
  mediaType          MediaType
  title              String
  overview           String
  posterPath         String?
  backdropPath       String?
  releaseDate        DateTime?
  runtimeMinutes     Int?
  genres             String[]               @default([])
  voteAverage        Float?
  popularity         Float?
  providerSnapshot   Json?
  metadataJson       Json?
  lastSyncedAt       DateTime               @default(now())
  interactions       UserTitleInteraction[]
  groupWatchSessions GroupWatchSession[]

  @@unique([tmdbId, mediaType])
}

model UserTitleInteraction {
  id              String          @id @default(cuid())
  userId          String
  titleCacheId    String
  interactionType InteractionType
  sourceContext   SourceContext   @default(MANUAL)
  groupRunId      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           TitleCache      @relation(fields: [titleCacheId], references: [id], onDelete: Cascade)

  @@unique([userId, titleCacheId, interactionType])
  @@index([userId, interactionType])
}

model RecommendationRun {
  id              String             @id @default(cuid())
  householdId     String
  mode            RecommendationMode
  requestedById   String
  selectedUserIds String[]
  filtersJson     Json?
  resultTitleIds  String[]
  explanationJson Json?
  createdAt       DateTime           @default(now())
  household       Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  requestedBy     User               @relation("RunRequester", fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([householdId, mode, createdAt])
}

model UserRecommendationContext {
  id              String             @id @default(cuid())
  userId          String             @unique
  householdId     String
  mode            RecommendationMode @default(SOLO)
  selectedUserIds String[]           @default([])
  savedGroupId    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  household       Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  savedGroup      HouseholdGroup?    @relation("SavedRecommendationContextGroup", fields: [savedGroupId], references: [id], onDelete: SetNull)

  @@index([householdId, updatedAt])
}

model GroupWatchSession {
  id                 String         @id @default(cuid())
  householdId        String
  titleCacheId       String
  createdById        String
  savedGroupId       String?
  participantKey     String
  participantUserIds String[]       @default([])
  watchedAt          DateTime       @default(now())
  createdAt          DateTime       @default(now())
  household          Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  title              TitleCache     @relation(fields: [titleCacheId], references: [id], onDelete: Cascade)
  createdBy          User           @relation("CreatedGroupWatchSessions", fields: [createdById], references: [id], onDelete: Cascade)
  savedGroup         HouseholdGroup? @relation("SavedGroupWatchSessions", fields: [savedGroupId], references: [id], onDelete: SetNull)

  @@unique([householdId, titleCacheId, participantKey])
  @@index([householdId, watchedAt])
}
