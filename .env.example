DATABASE_URL="postgresql://postgres:postgres@localhost:5432/screenlantern?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"
AI_PROVIDER="openai"
AI_BASE_URL=""
AI_API_KEY=""
AI_MODEL="gpt-5.4-mini"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-5.4-mini"
AI_USE_MOCK_DATA="0"
TMDB_API_KEY="your-tmdb-api-key"
TMDB_WATCH_REGION="US"
TMDB_USE_MOCK_DATA="0"
TRAKT_CLIENT_ID="your-trakt-client-id"
TRAKT_CLIENT_SECRET="your-trakt-client-secret"
TRAKT_REDIRECT_URI="http://localhost:3000/api/integrations/trakt/callback"
TRAKT_USE_MOCK_DATA="0"
INTERNAL_SYNC_SECRET="replace-with-a-separate-internal-sync-secret"
SEED_DEMO_MODE="full"
SCREENLANTERN_INTERNAL_URL="http://localhost:3000"
NETFLIX_SYNC_USER_EMAIL="your-screenlantern-user-email"
NETFLIX_SYNC_PROFILE_NAME=""
NETFLIX_SYNC_HEADLESS="1"
NETFLIX_SYNC_USER_DATA_DIR=".netflix-sync/profile"
NETFLIX_SYNC_STORAGE_STATE_PATH=".netflix-sync/storage-state.json"
NETFLIX_SYNC_DOWNLOAD_DIR=".netflix-sync/downloads"
# URL the Next.js app uses to reach the streaming-sync sidecar.
# In Docker Compose this is http://streaming-sync:7331. Leave blank to disable.
STREAMING_SYNC_URL="http://streaming-sync:7331"
# How often the sidecar auto-syncs Netflix history (hours). 0 = manual only.
NETFLIX_SYNC_INTERVAL_HOURS="24"
